# Template for all required env vars (see docs/architecture.md §7)
# Copy to backend/.env (development) and fill in real values.

# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/superusers"

# JWT secrets — must be at least 32 characters each
JWT_ACCESS_SECRET="replace-with-a-very-long-random-secret-min-32-chars"
JWT_REFRESH_SECRET="replace-with-another-very-long-random-secret-min-32"

# JWT TTLs in seconds
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# CORS — set to your frontend origin (Vercel URL in production)
FRONTEND_ORIGIN="http://localhost:5173"

# Server
PORT=3000
NODE_ENV=development

# bcrypt cost factor (10–15; production recommended: 12)
BCRYPT_ROUNDS=12

# Rate limiting — auth endpoints
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
LOGIN_RATE_LIMIT_MAX=10

# Account lockout
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=60

# Logging (trace | debug | info | warn | error)
LOG_LEVEL=info
